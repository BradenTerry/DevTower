{
  "name": "DevTower",
  "displayName": "DevTower",
  "description": "A pixel office tower for your coding agents - watch Claude sessions work, stack new floors, spawn devs into worktrees, review diffs and PRs.",
  "version": "0.4.0",
  "preview": true,
  "publisher": "BradenTerry",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/BradenTerry/DevTower.git"
  },
  "homepage": "https://github.com/BradenTerry/DevTower#readme",
  "bugs": {
    "url": "https://github.com/BradenTerry/DevTower/issues"
  },
  "keywords": [
    "claude",
    "claude code",
    "anthropic",
    "agents",
    "worktrees",
    "git",
    "pull requests",
    "code review"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devtower",
          "title": "DevTower",
          "icon": "media/devtower.svg"
        },
        {
          "id": "devtower-changes",
          "title": "DevTower Changes",
          "icon": "media/changes.svg"
        }
      ]
    },
    "views": {
      "devtower": [
        {
          "id": "devtower.directory",
          "name": "Selected Directory",
          "type": "tree"
        }
      ],
      "devtower-changes": [
        {
          "id": "devtower.changes",
          "name": "Changes",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "devtower.openConsole",
        "title": "DevTower: Open Tower",
        "icon": "$(screen-full)"
      },
      {
        "command": "devtower.refresh",
        "title": "DevTower: Refresh Agents",
        "icon": "$(refresh)"
      },
      {
        "command": "devtower.openSettings",
        "title": "DevTower: Open Settings"
      },
      {
        "command": "devtower.installHooks",
        "title": "DevTower: Install Notification Hook"
      },
      {
        "command": "devtower.openErrorLog",
        "title": "DevTower: Open Error Log"
      },
      {
        "command": "devtower.refreshChanges",
        "title": "DevTower: Refresh Changes",
        "icon": "$(refresh)"
      },
      {
        "command": "devtower.openFileDiff",
        "title": "DevTower: Open File Diff"
      },
      {
        "command": "devtower.stageFile",
        "title": "Stage Changes",
        "icon": "$(add)"
      },
      {
        "command": "devtower.unstageFile",
        "title": "Unstage Changes",
        "icon": "$(remove)"
      },
      {
        "command": "devtower.stageAll",
        "title": "Stage All Changes",
        "icon": "$(add)"
      },
      {
        "command": "devtower.unstageAll",
        "title": "Unstage All Changes",
        "icon": "$(remove)"
      },
      {
        "command": "devtower.discardFile",
        "title": "Discard Changes",
        "icon": "$(discard)"
      },
      {
        "command": "devtower.discardAll",
        "title": "Discard All Changes",
        "icon": "$(discard)"
      },
      {
        "command": "devtower.stageDir",
        "title": "Stage Changes",
        "icon": "$(add)"
      },
      {
        "command": "devtower.unstageDir",
        "title": "Unstage Changes",
        "icon": "$(remove)"
      },
      {
        "command": "devtower.discardDir",
        "title": "Discard Changes",
        "icon": "$(discard)"
      },
      {
        "command": "devtower.addToGitignore",
        "title": "Add to .gitignore"
      },
      {
        "command": "devtower.refreshDirectory",
        "title": "DevTower: Refresh Selected Directory",
        "icon": "$(refresh)"
      },
      {
        "command": "devtower.deleteFile",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "devtower.resetFilePrompts",
        "title": "DevTower: Reset File Prompt Confirmations"
      },
      {
        "command": "devtower.changesViewAsTree",
        "title": "DevTower: View Changes as Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "devtower.changesViewAsList",
        "title": "DevTower: View Changes as List",
        "icon": "$(list-flat)"
      },
      {
        "command": "devtower.commit",
        "title": "Commit",
        "icon": "$(check)"
      },
      {
        "command": "devtower.commitAmend",
        "title": "Commit (Amend)",
        "icon": "$(check)"
      },
      {
        "command": "devtower.commitPush",
        "title": "Commit & Push",
        "icon": "$(arrow-up)"
      },
      {
        "command": "devtower.commitSync",
        "title": "Commit & Sync",
        "icon": "$(sync)"
      },
      {
        "command": "devtower.collapseChanges",
        "title": "Collapse All",
        "icon": "$(collapse-all)"
      },
      {
        "command": "devtower.push",
        "title": "DevTower: Push",
        "icon": "$(repo-push)"
      },
      {
        "command": "devtower.fetch",
        "title": "DevTower: Fetch",
        "icon": "$(cloud-download)"
      },
      {
        "command": "devtower.stash",
        "title": "DevTower: Stash Changes",
        "icon": "$(archive)"
      },
      {
        "command": "devtower.stashPop",
        "title": "DevTower: Pop Stash",
        "icon": "$(arrow-up)"
      },
      {
        "command": "devtower.stashApply",
        "title": "DevTower: Apply Stash",
        "icon": "$(diff-added)"
      },
      {
        "command": "devtower.stashDrop",
        "title": "DevTower: Drop Stash",
        "icon": "$(trash)"
      }
    ],
    "submenus": [
      {
        "id": "devtower.commitMenu",
        "label": "Commit",
        "icon": "$(check)"
      }
    ],
    "menus": {
      "devtower.commitMenu": [
        {
          "command": "devtower.commit",
          "group": "1_commit@1"
        },
        {
          "command": "devtower.commitAmend",
          "group": "1_commit@2"
        },
        {
          "command": "devtower.commitPush",
          "group": "2_remote@1"
        },
        {
          "command": "devtower.commitSync",
          "group": "2_remote@2"
        }
      ],
      "view/title": [
        {
          "command": "devtower.openConsole",
          "when": "view == devtower.directory",
          "group": "navigation@0"
        },
        {
          "command": "devtower.refreshDirectory",
          "when": "view == devtower.directory",
          "group": "navigation@2"
        },
        {
          "command": "devtower.changesViewAsTree",
          "when": "view == devtower.changes && devtower.changesView == flat",
          "group": "navigation@0"
        },
        {
          "command": "devtower.changesViewAsList",
          "when": "view == devtower.changes && devtower.changesView == tree",
          "group": "navigation@0"
        },
        {
          "command": "devtower.stageAll",
          "when": "view == devtower.changes",
          "group": "navigation@1"
        },
        {
          "command": "devtower.unstageAll",
          "when": "view == devtower.changes",
          "group": "navigation@2"
        },
        {
          "submenu": "devtower.commitMenu",
          "when": "view == devtower.changes",
          "group": "navigation@3"
        },
        {
          "command": "devtower.push",
          "when": "view == devtower.changes",
          "group": "navigation@4"
        },
        {
          "command": "devtower.fetch",
          "when": "view == devtower.changes",
          "group": "navigation@5"
        },
        {
          "command": "devtower.stash",
          "when": "view == devtower.changes",
          "group": "navigation@6"
        },
        {
          "command": "devtower.refreshChanges",
          "when": "view == devtower.changes",
          "group": "navigation@7"
        },
        {
          "command": "devtower.collapseChanges",
          "when": "view == devtower.changes",
          "group": "navigation@8"
        }
      ],
      "view/item/context": [
        {
          "command": "devtower.deleteFile",
          "when": "view == devtower.directory && viewItem == file",
          "group": "9_delete@1"
        },
        {
          "command": "devtower.deleteFile",
          "when": "view == devtower.directory && viewItem == dir",
          "group": "9_delete@1"
        },
        {
          "command": "devtower.discardFile",
          "when": "view == devtower.changes && viewItem == unstaged",
          "group": "inline@1"
        },
        {
          "command": "devtower.stageFile",
          "when": "view == devtower.changes && viewItem == unstaged",
          "group": "inline@2"
        },
        {
          "command": "devtower.unstageFile",
          "when": "view == devtower.changes && viewItem == staged",
          "group": "inline@2"
        },
        {
          "command": "devtower.discardAll",
          "when": "view == devtower.changes && viewItem == group-unstaged",
          "group": "inline@1"
        },
        {
          "command": "devtower.stageAll",
          "when": "view == devtower.changes && viewItem == group-unstaged",
          "group": "inline@2"
        },
        {
          "command": "devtower.unstageAll",
          "when": "view == devtower.changes && viewItem == group-staged",
          "group": "inline@2"
        },
        {
          "command": "devtower.discardAll",
          "when": "view == devtower.changes && viewItem == group-unstaged",
          "group": "1_modification@1"
        },
        {
          "command": "devtower.stageAll",
          "when": "view == devtower.changes && viewItem == group-unstaged",
          "group": "1_modification@2"
        },
        {
          "command": "devtower.collapseChanges",
          "when": "view == devtower.changes && viewItem == group-unstaged",
          "group": "9_view@1"
        },
        {
          "command": "devtower.unstageAll",
          "when": "view == devtower.changes && viewItem == group-staged",
          "group": "1_modification@1"
        },
        {
          "command": "devtower.collapseChanges",
          "when": "view == devtower.changes && viewItem == group-staged",
          "group": "9_view@1"
        },
        {
          "command": "devtower.stageFile",
          "when": "view == devtower.changes && viewItem == unstaged",
          "group": "1_modification@2"
        },
        {
          "command": "devtower.discardFile",
          "when": "view == devtower.changes && viewItem == unstaged",
          "group": "1_modification@1"
        },
        {
          "command": "devtower.unstageFile",
          "when": "view == devtower.changes && viewItem == staged",
          "group": "1_modification@1"
        },
        {
          "command": "devtower.discardDir",
          "when": "view == devtower.changes && viewItem == dir-unstaged",
          "group": "inline@1"
        },
        {
          "command": "devtower.stageDir",
          "when": "view == devtower.changes && viewItem == dir-unstaged",
          "group": "inline@2"
        },
        {
          "command": "devtower.unstageDir",
          "when": "view == devtower.changes && viewItem == dir-staged",
          "group": "inline@2"
        },
        {
          "command": "devtower.stageDir",
          "when": "view == devtower.changes && viewItem == dir-unstaged",
          "group": "1_modification@2"
        },
        {
          "command": "devtower.discardDir",
          "when": "view == devtower.changes && viewItem == dir-unstaged",
          "group": "1_modification@1"
        },
        {
          "command": "devtower.unstageDir",
          "when": "view == devtower.changes && viewItem == dir-staged",
          "group": "1_modification@1"
        },
        {
          "command": "devtower.addToGitignore",
          "when": "view == devtower.changes && viewItem == unstaged",
          "group": "9_gitignore@1"
        },
        {
          "command": "devtower.addToGitignore",
          "when": "view == devtower.changes && viewItem == staged",
          "group": "9_gitignore@1"
        },
        {
          "command": "devtower.addToGitignore",
          "when": "view == devtower.changes && viewItem == dir-unstaged",
          "group": "9_gitignore@1"
        },
        {
          "command": "devtower.addToGitignore",
          "when": "view == devtower.changes && viewItem == dir-staged",
          "group": "9_gitignore@1"
        },
        {
          "command": "devtower.stashPop",
          "when": "view == devtower.changes && viewItem == stash",
          "group": "inline@1"
        },
        {
          "command": "devtower.stashApply",
          "when": "view == devtower.changes && viewItem == stash",
          "group": "inline@2"
        },
        {
          "command": "devtower.stashDrop",
          "when": "view == devtower.changes && viewItem == stash",
          "group": "inline@3"
        },
        {
          "command": "devtower.stashPop",
          "when": "view == devtower.changes && viewItem == stash",
          "group": "1_stash@1"
        },
        {
          "command": "devtower.stashApply",
          "when": "view == devtower.changes && viewItem == stash",
          "group": "1_stash@2"
        },
        {
          "command": "devtower.stashDrop",
          "when": "view == devtower.changes && viewItem == stash",
          "group": "1_stash@3"
        }
      ],
      "commandPalette": [
        {
          "command": "devtower.openFileDiff",
          "when": "false"
        },
        {
          "command": "devtower.stageFile",
          "when": "false"
        },
        {
          "command": "devtower.unstageFile",
          "when": "false"
        },
        {
          "command": "devtower.discardFile",
          "when": "false"
        },
        {
          "command": "devtower.stageDir",
          "when": "false"
        },
        {
          "command": "devtower.unstageDir",
          "when": "false"
        },
        {
          "command": "devtower.discardDir",
          "when": "false"
        },
        {
          "command": "devtower.addToGitignore",
          "when": "false"
        },
        {
          "command": "devtower.stashPop",
          "when": "false"
        },
        {
          "command": "devtower.stashApply",
          "when": "false"
        },
        {
          "command": "devtower.stashDrop",
          "when": "false"
        },
        {
          "command": "devtower.collapseChanges",
          "when": "false"
        },
        {
          "command": "devtower.deleteFile",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "DevTower",
      "properties": {
        "devtower.stateFile": {
          "type": "string",
          "default": ".devtower/state.jsonl",
          "description": "Path (relative to the first workspace folder, or absolute) to the append-only JSONL file agents write state events to."
        },
        "devtower.discoverClaudeSessions": {
          "type": "boolean",
          "default": true,
          "description": "Scan ~/.claude/projects for live Claude Code CLI sessions and show them in the tower."
        },
        "devtower.pollIntervalMs": {
          "type": "number",
          "default": 8000,
          "description": "How often (ms) to rescan for live Claude sessions. Lower = sessions leave the tower sooner after Claude exits, at the cost of more frequent ps/lsof checks."
        },
        "devtower.sessionMaxAgeHours": {
          "type": "number",
          "default": 24,
          "description": "How far back to scan transcripts when looking for sessions (the candidate pool; running-process check still applies)."
        },
        "devtower.showRecentSessions": {
          "type": "boolean",
          "default": false,
          "description": "Also show recent Claude sessions that have no running process (as idle, resumable rooms). Off = only sessions actually running right now."
        },
        "devtower.debugLog": {
          "type": "boolean",
          "default": false,
          "description": "Write a structured debug log of agent discovery, session binding, external/internal classification, terminals, and scene events to the \"DevTower Debug\" output channel and .devtower/debug.log. For diagnosing agent issues; leave off in normal use."
        },
        "devtower.efficiencyMode": {
          "type": "boolean",
          "default": false,
          "description": "Reduce animation/particle work in the tower to save CPU. Toggle from the ⚡ button in the tower; your choice is saved here."
        },
        "devtower.claudeCommand": {
          "type": "string",
          "default": "claude",
          "description": "Command launched in a new agent's terminal when you add a dev to a room (starts a fresh Claude session in that worktree). Ignored if launchCommand is set."
        },
        "devtower.launchCommand": {
          "type": "string",
          "default": "",
          "description": "Overrides claudeCommand: command run in an agent's terminal on first open. Placeholders: ${worktree}, ${branch}, ${id}."
        },
        "devtower.reviewSkills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "code-review",
            "security-review",
            "review",
            "simplify",
            "verify"
          ],
          "description": "Skills (slash commands) offered as selectable chips in the Review Dispatch card when assigning an agent to review a PR."
        },
        "devtower.reviewDefaults": {
          "type": "object",
          "default": {},
          "properties": {
            "skills": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Skills pre-selected when the Review Dispatch card opens."
            },
            "effort": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "max"
              ],
              "description": "Default effort level for code-review/review skills."
            },
            "instructions": {
              "type": "string",
              "description": "Default reviewer instructions pre-filled in the card."
            }
          },
          "description": "Saved defaults for the Review Dispatch card. Written when you check \"Save as default\" while dispatching a review."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "compile": "node esbuild.js",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npx --yes @vscode/vsce package --readme-path MARKETPLACE.md",
    "screenshots": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
